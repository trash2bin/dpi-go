# Go build artifacts
/dpi
/bin/
/build/
/dist/
/out/
*.exe
*.dll
*.so
*.dylib
*.test

# Test and coverage output
coverage.out
coverage.html
*.coverprofile
*.prof

# Local Go workspace files
go.work
go.work.sum

# Runtime logs and temporary files
*.log
/logs/
/tmp/
*.tmp

# Local configuration overrides
.env
.env.*
*.local
configs/*.local.toml

# Packet captures: keep committed fixtures, ignore ad-hoc captures
!docker/pcap/**/*.pcap

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Office temporary files
~$*.docx
.~lock.*
*.docx

# OpenVPN test (some files has GPLv2 LICENSE)
*.key
/docker/pcap/openvpn/ovpn-static/down.sh
/docker/pcap/openvpn/ovpn-static/up.sh

